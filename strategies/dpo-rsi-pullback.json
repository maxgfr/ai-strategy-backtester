{
  "name": "dpo-rsi-pullback",
  "description": "DPO rising cycle detection with RSI pullback in Supertrend uptrend",
  "indicators": {
    "dpo": { "period": 20 },
    "rsi": { "period": 14 },
    "supertrend": { "period": 10, "multiplier": 3 }
  },
  "buy": {
    "mode": "all",
    "conditions": [
      ["dpo", ">", "dpo[-1]"],
      ["rsi", "<", 40],
      ["supertrend.direction", "==", 1]
    ]
  },
  "sell": {
    "mode": "any",
    "conditions": [["rsi", ">", 75], ["supertrend.direction", "==", -1]]
  }
}
