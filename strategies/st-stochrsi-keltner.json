{
  "name": "st-stochrsi-keltner",
  "description": "StochRSI oversold near Keltner lower band — momentum recovery scalper with volume confirmation",
  "indicators": {
    "stochRsi": {
      "rsiPeriod": 7,
      "stochasticPeriod": 7,
      "kPeriod": 3,
      "dPeriod": 3
    },
    "keltner": { "maPeriod": 10, "atrPeriod": 10, "multiplier": 1.5 },
    "volumeSma": { "period": 10 }
  },
  "buy": {
    "mode": "all",
    "conditions": [
      ["stochRsi.k", "<", 20],
      ["close", "<", "keltner.lower"],
      ["volume", ">", "volumeSma"]
    ]
  },
  "sell": {
    "mode": "any",
    "conditions": [["stochRsi.k", ">", 80], ["close", ">", "keltner.upper"]]
  }
}
