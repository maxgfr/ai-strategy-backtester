{
  "name": "st-stochrsi-keltner",
  "description": "StochRSI deeply oversold near Keltner lower in Supertrend uptrend — catches momentum recoveries in confirmed trends",
  "indicators": {
    "stochRsi": {
      "rsiPeriod": 14,
      "stochasticPeriod": 14,
      "kPeriod": 3,
      "dPeriod": 3
    },
    "keltner": { "maPeriod": 20, "atrPeriod": 10, "multiplier": 1.5 },
    "supertrend": { "atrPeriod": 10, "multiplier": 3 },
    "volumeSma": { "period": 20 }
  },
  "buy": {
    "mode": "all",
    "conditions": [
      ["close", ">", "supertrend"],
      ["stochRsi.k", "<", 15],
      ["close", "<", "keltner.lower"],
      ["volume", ">", "volumeSma"]
    ]
  },
  "sell": {
    "mode": "any",
    "conditions": [["close", "<", "supertrend"], ["stochRsi.k", ">", 90]]
  }
}
