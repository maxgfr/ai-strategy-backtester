{
  "name": "pmax",
  "description": "PMAX trend following — buy when pmax equals pmaxLong, sell when pmax equals pmaxShort",
  "indicators": {
    "pmax": { "emaPeriod": 10, "atrPeriod": 10, "multiplier": 3 }
  },
  "buy": {
    "mode": "all",
    "conditions": [["pmax.pmax", "==", "pmax.pmaxLong"]]
  },
  "sell": {
    "mode": "all",
    "conditions": [["pmax.pmax", "==", "pmax.pmaxShort"]]
  }
}
