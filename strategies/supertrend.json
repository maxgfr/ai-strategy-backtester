{
  "name": "supertrend",
  "description": "Supertrend trend following — buy when close is above supertrend, sell when below",
  "indicators": {
    "supertrend": { "atrPeriod": 10, "multiplier": 3 }
  },
  "buy": {
    "mode": "all",
    "conditions": [["close", ">", "supertrend"]]
  },
  "sell": {
    "mode": "all",
    "conditions": [["close", "<", "supertrend"]]
  }
}
