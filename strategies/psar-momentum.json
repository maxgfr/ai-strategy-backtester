{
  "name": "psar-momentum",
  "description": "Parabolic SAR trend following with ROC momentum and RSI filter",
  "indicators": {
    "psar": { "step": 0.02, "max": 0.2 },
    "roc": { "period": 12 },
    "rsi": { "period": 14 }
  },
  "buy": {
    "mode": "all",
    "conditions": [["close", ">", "psar"], ["roc", ">", 0], ["rsi", "<", 60]]
  },
  "sell": {
    "mode": "any",
    "conditions": [["close", "<", "psar"], ["rsi", ">", 75]]
  }
}
