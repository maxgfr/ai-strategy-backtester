    "conditions": [
      ["close", ">", "vwma"],
      ["vwma", ">", "movingAverage"],
      ["choppinessIndex", "<", 50],
      ["rsi", ">", 50]
    ]
  },
  "sell": {
    "mode": "any",
    "conditions": [["close", "<", "vwma"], ["choppinessIndex", ">", 61.8]]
  }
}
