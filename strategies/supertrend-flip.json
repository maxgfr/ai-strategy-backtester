{
  "name": "supertrend-flip",
  "description": "Supertrend trend flip — long when above, short when below. Always in a position.",
  "leverage": 2,
  "indicators": {
    "supertrend": { "atrPeriod": 10, "multiplier": 3 }
  },
  "buy": {
    "mode": "all",
    "conditions": [["close", ">", "supertrend"]]
  },
  "sell": {
    "mode": "all",
    "conditions": [["close", "<", "supertrend"]]
  },
  "short": {
    "mode": "all",
    "conditions": [["close", "<", "supertrend"]]
  },
  "cover": {
    "mode": "all",
    "conditions": [["close", ">", "supertrend"]]
  }
}
