{
  "name": "kdj-ema-scalp",
  "description": "KDJ J-line oversold recovery in Supertrend uptrend — catches V-reversals with volume spike, exits only on trend break",
  "indicators": {
    "kdj": { "rsvPeriod": 9, "kPeriod": 3, "dPeriod": 3 },
    "supertrend": { "atrPeriod": 10, "multiplier": 3 },
    "volumeSma": { "period": 20 }
  },
  "buy": {
    "mode": "all",
    "conditions": [
      ["close", ">", "supertrend"],
      ["kdj.j", "<", 20],
      ["volume", ">", "volumeSma"]
    ]
  },
  "sell": {
    "mode": "all",
    "conditions": [["close", "<", "supertrend"]]
  }
}
