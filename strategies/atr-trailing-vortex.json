{
  "name": "atr-trailing-vortex",
  "description": "Vortex crossover (plusVI crosses above minusVI) + ATR trailing stop as dynamic exit + ADX trending — trend inception detection with intelligent trailing stop management",
  "indicators": {
    "vortex": { "period": 14 },
    "atrTrailingStop": { "period": 14, "multiplier": 3 },
    "adx": { "period": 14 },
    "rsi": { "period": 14 },
    "macd": { "fast": 12, "slow": 26, "signal": 9 }
  },
  "buy": {
    "mode": "all",
    "conditions": [
      ["vortex.plusVI", ">", "vortex.minusVI"],
      ["vortex.plusVI[-1]", "<", "vortex.minusVI[-1]"],
      ["adx.adx", ">", 20],
      ["macd.histogram", ">", 0],
      ["rsi", "<", 55]
    ]
  },
  "sell": {
    "mode": "any",
    "conditions": [
      ["close", "<", "atrTrailingStop.stop"],
      ["vortex.minusVI", ">", "vortex.plusVI"],
      ["rsi", ">", 78]
    ]
  }
}
