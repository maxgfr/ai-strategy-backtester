{
  "name": "mean-reversion-bb",
  "description": "Bollinger Bands mean reversion — buy at lower band with RSI oversold, sell at middle band or RSI overbought",
  "indicators": {
    "bollingerBands": { "period": 20, "stdDev": 2 },
    "rsi": { "period": 14 },
    "volumeSma": { "period": 20 }
  },
  "buy": {
    "mode": "all",
    "conditions": [
      ["close", "<", "bollingerBands.lower"],
      ["rsi", "<", 35],
      ["volume", ">", "volumeSma"]
    ]
  },
  "sell": {
    "mode": "any",
    "conditions": [["close", ">", "bollingerBands.middle"], ["rsi", ">", 70]]
  }
}
