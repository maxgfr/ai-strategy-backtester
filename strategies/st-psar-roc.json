{
  "name": "st-psar-roc",
  "description": "PSAR trend flip in Supertrend uptrend — standard PSAR with ROC momentum and CMF flow, exits on trend break or PSAR flip",
  "indicators": {
    "psar": { "step": 0.02, "max": 0.2 },
    "roc": { "period": 10 },
    "cmf": { "period": 14 },
    "supertrend": { "atrPeriod": 10, "multiplier": 3 }
  },
  "buy": {
    "mode": "all",
    "conditions": [
      ["close", ">", "supertrend"],
      ["close", ">", "psar"],
      ["roc", ">", 0],
      ["cmf", ">", 0]
    ]
  },
  "sell": {
    "mode": "any",
    "conditions": [["close", "<", "supertrend"], ["close", "<", "psar"]]
  }
}
