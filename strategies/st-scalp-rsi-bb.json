{
  "name": "st-scalp-rsi-bb",
  "description": "BB mean reversion in Supertrend uptrend — buy near lower BB when RSI oversold with volume spike, exit on trend break or upper BB",
  "indicators": {
    "bollingerBands": { "period": 20, "stdDev": 2 },
    "rsi": { "period": 10 },
    "supertrend": { "atrPeriod": 10, "multiplier": 3 },
    "volumeSma": { "period": 20 }
  },
  "buy": {
    "mode": "all",
    "conditions": [
      ["close", ">", "supertrend"],
      ["close", "<", "bollingerBands.lower"],
      ["rsi", "<", 30],
      ["volume", ">", "volumeSma"]
    ]
  },
  "sell": {
    "mode": "any",
    "conditions": [
      ["close", "<", "supertrend"],
      ["close", ">", "bollingerBands.upper"],
      ["rsi", ">", 75]
    ]
  }
}
