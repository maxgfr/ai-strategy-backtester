{
  "name": "rsi-reversal",
  "description": "RSI mean reversion long/short — buy oversold, short overbought, with MACD confirmation",
  "leverage": 2,
  "indicators": {
    "rsi": { "period": 14 },
    "macd": { "fast": 12, "slow": 26, "signal": 9 }
  },
  "buy": {
    "mode": "all",
    "conditions": [["rsi", "<", 30], ["macd.histogram", ">", 0]]
  },
  "sell": {
    "mode": "any",
    "conditions": [["rsi", ">", 70]]
  },
  "short": {
    "mode": "all",
    "conditions": [["rsi", ">", 75], ["macd.histogram", "<", 0]]
  },
  "cover": {
    "mode": "any",
    "conditions": [["rsi", "<", 35]]
  }
}
